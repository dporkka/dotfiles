// =============================================================================
// Zellij config — Neovim-first, conflict-free keybindings
// =============================================================================

simplified_ui false
pane_frames true
mouse_mode true
scroll_buffer_size 10000
copy_on_select true
default_shell "zsh"

keybinds {
    shared_except "locked" {
        // LazyVim binds Alt+j/k for moving lines up/down.
        // Zellij's default combines "Alt j" + "Alt Down" as one binding — we
        // split them so arrows still navigate panes but Alt+j/k pass through.
        unbind "Alt j" "Alt Down"
        unbind "Alt k" "Alt Up"
        bind "Alt Down" { MoveFocus "Down"; }
        bind "Alt Up"   { MoveFocus "Up"; }

        // Neovim conflicts — removed from all modes:
        unbind "Ctrl h"  // Neovim: window nav left (zellij-nav.nvim uses this)
        unbind "Ctrl n"  // Neovim: completion next (insert mode)
        unbind "Ctrl o"  // Neovim: jumplist back (used constantly)
        unbind "Ctrl s"  // Oil.nvim: open in split
        unbind "Ctrl t"  // Oil.nvim: open in tab
        unbind "Ctrl b"  // Neovim: page up

        // Direct Alt-key shortcuts for common Zellij operations
        bind "Alt t"  { NewTab; SwitchToMode "Normal"; }
        bind "Alt d"  { Detach; }
        bind "Alt x"  { CloseFocus; SwitchToMode "Normal"; }
        bind "Alt r"  { SwitchToMode "Resize"; }
        bind "Alt \\" { NewPane "Right"; SwitchToMode "Normal"; }
        bind "Alt -"  { NewPane "Down"; SwitchToMode "Normal"; }
    }

    resize {
        bind "Alt r" { SwitchToMode "Normal"; }
        bind "Esc"   { SwitchToMode "Normal"; }
    }

    // Locked mode: Ctrl+g enters, Ctrl+g exits.
    // Use this when you need 100% Neovim passthrough (e.g. Oil, terminal mode).
    locked {
        bind "Ctrl g" { SwitchToMode "Normal"; }
    }
}
