{
    "$help": "Windows Terminal settings — save to %LOCALAPPDATA%\\Packages\\Microsoft.WindowsTerminal_8wekyb3d8bbwe\\LocalState\\settings.json",
    "$schema": "https://aka.ms/terminal-settings-schema",

    "defaultProfile": "{your-wsl-ubuntu-guid}",
    "startOnUserLogin": false,
    "copyOnSelect": false,
    "copyFormatting": "none",
    "wordDelimiters": " /\\()\"'-.,:;<>~!@#$%^&*|+=[]{}~?│",

    "profiles": {
        "defaults": {
            "font": {
                "face": "Cascadia Code NF",
                "size": 12,
                "weight": "normal",
                "features": {
                    "calt": 1,
                    "liga": 1
                }
            },
            "scrollbarState": "hidden",
            "padding": "8, 8, 8, 8",
            "antialiasingMode": "cleartype",
            "closeOnExit": "automatic",
            "bellStyle": "none",
            "experimental.retroTerminalEffect": false,
            "colorScheme": "Tokyo Night Storm"
        },
        "list": [
            {
                "name": "Ubuntu WSL2",
                "guid": "{your-wsl-ubuntu-guid}",
                "source": "Windows.Terminal.Wsl",
                "startingDirectory": "//wsl.localhost/Ubuntu/home/dporkka",
                "commandline": "wsl.exe -d Ubuntu",
                "hidden": false,
                "icon": "ms-appx:///ProfileIcons/{9acb9455-ca41-5af7-950f-6bca1bc9722f}.png"
            },
            {
                "name": "Ubuntu WSL2 (tmux)",
                "guid": "{tmux-profile-guid}",
                "source": "Windows.Terminal.Wsl",
                "startingDirectory": "//wsl.localhost/Ubuntu/home/dporkka",
                "commandline": "wsl.exe -d Ubuntu -- tmux new-session -A -s main",
                "hidden": false
            },
            {
                "name": "PowerShell",
                "guid": "{61c54bbd-c2c6-5271-96e7-009a87ff44bf}",
                "hidden": false
            }
        ]
    },

    "schemes": [
        {
            "name": "Tokyo Night Storm",
            "background": "#24283b",
            "foreground": "#a9b1d6",
            "selectionBackground": "#28344a",
            "cursorColor": "#c0caf5",
            "black": "#1d202f",
            "blue": "#7aa2f7",
            "brightBlack": "#414868",
            "brightBlue": "#7aa2f7",
            "brightCyan": "#7dcfff",
            "brightGreen": "#9ece6a",
            "brightPurple": "#9d7cd8",
            "brightRed": "#f7768e",
            "brightWhite": "#c0caf5",
            "brightYellow": "#e0af68",
            "cyan": "#7dcfff",
            "green": "#9ece6a",
            "purple": "#9d7cd8",
            "red": "#f7768e",
            "white": "#a9b1d6",
            "yellow": "#e0af68"
        }
    ],

    "keybindings": [
        { "command": "find", "keys": "ctrl+shift+f" },
        { "command": { "action": "splitPane", "split": "horizontal" }, "keys": "alt+shift+-" },
        { "command": { "action": "splitPane", "split": "vertical" }, "keys": "alt+shift+="},
        { "command": { "action": "moveFocus", "direction": "left" }, "keys": "alt+left" },
        { "command": { "action": "moveFocus", "direction": "right" }, "keys": "alt+right" },
        { "command": { "action": "moveFocus", "direction": "up" }, "keys": "alt+up" },
        { "command": { "action": "moveFocus", "direction": "down" }, "keys": "alt+down" },
        { "command": "toggleFullscreen", "keys": "f11" },
        { "command": { "action": "newTab" }, "keys": "ctrl+t" },
        { "command": "closeTab", "keys": "ctrl+w" },
        { "command": { "action": "copy", "singleLine": false }, "keys": "ctrl+c" },
        { "command": "paste", "keys": "ctrl+v" }
    ],

    "actions": [
        {
            "command": {
                "action": "wt",
                "commandline": "wsl.exe -d Ubuntu -- tmux new-session -A -s main"
            },
            "name": "Open tmux"
        }
    ]
}
